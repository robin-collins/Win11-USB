.env
.env.*
!/.env.example

# Generated unattend files may contain local administrator passwords.
Autounattend.generated.xml
Autounattend.local.xml

# Generated WinPE partitioning artifacts (written to the USB root by Initialize-UsbDeployment.ps1)
OSIT-DiskPart.txt
OSIT-DiskPart.log

# Deployment runtime output
Deployment/State/*.json
Deployment/State/*.bak
Deployment/State/*.archive-*.json
Deployment/Logs/*
!Deployment/Logs/.gitkeep
Deployment/Reports/*
!Deployment/Reports/.gitkeep

# Local app and driver payloads are usually large and site-specific.
Deployment/Apps/Local/*
!Deployment/Apps/Local/.gitkeep
Deployment/Apps/Winget/*
!Deployment/Apps/Winget/.gitkeep
Deployment/Drivers/*/*
!Deployment/Drivers/Dell/.gitkeep
!Deployment/Drivers/HP/.gitkeep
!Deployment/Drivers/Lenovo/.gitkeep
!Deployment/Drivers/Generic/.gitkeep

# Network/WiFi driver vendor folders are nested one level deeper (Drivers/Network/<Vendor>),
# so the vendor directories themselves must be re-included before their contents can be
# re-ignored, or their .gitkeep placeholders would be excluded along with real driver payloads.
!Deployment/Drivers/Network/*/
Deployment/Drivers/Network/*/*
!Deployment/Drivers/Network/*/.gitkeep

# Hyper-V rehearsal harness (Test\Rehearsal, Tier 1) is host-side only and never ships on the
# USB. Per-run scratch state, harvested artifacts, and rehearsal secrets must never be
# committed; the bench technician's own working directory (default
# %TEMP%\DeploymentRehearsal) already lives outside the repo, but anything the harness writes
# under the repo tree itself is excluded here.
Test/Rehearsal/Artifacts/*
!Test/Rehearsal/Artifacts/.gitkeep
Test/Rehearsal/.working/
Test/Rehearsal/**/.env
Test/Rehearsal/**/*.env
